C;EACb,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;EAC9B,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;AACrB","file":"C:/Users/Administrator/Desktop/HeartDisease/frontend/src/views/user/Prediction.vue","sourceRoot":"","sourcesContent":["<template>\r\n    <div class=\"doctor-prediction\">\r\n      <h1>医生预测页面</h1>\r\n      <p>在这里医生可以进行心脏病风险预测</p>\r\n      \r\n      <el-card class=\"box-card\">\r\n        <template #header>\r\n          <div class=\"card-header\">\r\n            <h2>心脏病风险预测</h2>\r\n          </div>\r\n        </template>\r\n        \r\n        <el-form :model=\"formData\" label-width=\"120px\">\r\n          <el-form-item label=\"患者姓名\">\r\n            <el-input v-model=\"formData.patientName\" placeholder=\"请输入患者姓名\"></el-input>\r\n          </el-form-item>\r\n          \r\n          <el-form-item label=\"年龄\">\r\n            <el-input-number v-model=\"formData.age\" :min=\"1\" :max=\"120\"></el-input-number>\r\n          </el-form-item>\r\n          \r\n          <el-form-item label=\"性别\">\r\n            <el-radio-group v-model=\"formData.gender\">\r\n              <el-radio :value=\"'male'\">男</el-radio>\r\n              <el-radio :value=\"'female'\">女</el-radio>\r\n            </el-radio-group>\r\n          </el-form-item>\r\n          \r\n          <el-form-item>\r\n            <el-button type=\"primary\" @click=\"handlePredict\">预测</el-button>\r\n            <el-button @click=\"resetForm\">重置</el-button>\r\n          </el-form-item>\r\n        </el-form>\r\n      </el-card>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  import { reactive } from 'vue'\r\n\r\n  export default {\r\n    name: \"DoctorPrediction\",\r\n    setup() {\r\n      const formData = reactive({\r\n        patientName: '',\r\n        age: 30,\r\n        gender: 'male'\r\n      })\r\n      \r\n      const handlePredict = () => {\r\n        console.log('预测数据:', formData)\r\n        // 这里添加预测逻辑\r\n      }\r\n      \r\n      const resetForm = () => {\r\n        formData.patientName = ''\r\n        formData.age = 30\r\n        formData.gender = 'male'\r\n      }\r\n      \r\n      return {\r\n        formData,\r\n        handlePredict,\r\n        resetForm\r\n      }\r\n    }\r\n  }\r\n  </script>\r\n\r\n<style scoped>\r\n.doctor-prediction {\r\n  padding: 20px;\r\n}\r\n\r\n.box-card {\r\n  margin-top: 20px;\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n</style>"]}]}