,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;QACjE,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;MAC/C,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;IACV,CAAC,CAAC,CAAC,CAAC,CAAC;EACP,CAAC,CAAC,CAAC,CAAC,CAAC","file":"C:/Users/Administrator/Desktop/HeartDisease/frontend/src/views/doctor/Dashboard.vue","sourceRoot":"","sourcesContent":["<template>\r\n  <div class=\"dashboard\">\r\n    <h2 class=\"mb-4\">仪表盘</h2>\r\n    \r\n    <div class=\"row\">\r\n      <!-- 统计卡片 -->\r\n\r\n      \r\n      <div class=\"col-md-3 mb-4\">\r\n        <div class=\"card bg-info text-white h-100\">\r\n          <div class=\"card-body d-flex flex-column align-items-start\">\r\n            <div class=\"d-flex align-items-center w-100 mb-2\">\r\n              <i class=\"bi bi-graph-up me-2 fs-4\"></i>\r\n              <h5 class=\"card-title mb-0\">预测次数</h5>\r\n            </div>\r\n            <h2 class=\"card-text mt-2\">{{ stats.predictions || 0 }}</h2>\r\n            <small class=\"mt-auto\">已完成的风险预测总数</small>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      \r\n      <div class=\"col-md-3 mb-4\">\r\n        <div class=\"card bg-warning text-white h-100\">\r\n          <div class=\"card-body d-flex flex-column align-items-start\">\r\n            <div class=\"d-flex align-items-center w-100 mb-2\">\r\n              <i class=\"bi bi-exclamation-triangle-fill me-2 fs-4\"></i>\r\n              <h5 class=\"card-title mb-0\">高风险病例</h5>\r\n            </div>\r\n            <h2 class=\"card-text mt-2\">{{ stats.highRisk || 0 }}</h2>\r\n            <small class=\"mt-auto\">被判定为高风险的病例数</small>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 最近活动 -->\r\n    <div class=\"card\">\r\n      <div class=\"card-header bg-light\">\r\n        <div class=\"d-flex align-items-center\">\r\n          <i class=\"bi bi-activity me-2\"></i>\r\n          <h5 class=\"card-title mb-0\">最近活动</h5>\r\n        </div>\r\n      </div>\r\n      <div class=\"card-body\">\r\n        <div class=\"list-group\">\r\n          <a v-for=\"activity in recentActivities\" \r\n             :key=\"activity.id\" \r\n             href=\"#\" \r\n             class=\"list-group-item list-group-item-action\">\r\n            <div class=\"d-flex w-100 justify-content-between\">\r\n              <h6 class=\"mb-1\">\r\n                <i v-if=\"activity.id.startsWith('file_')\" class=\"bi bi-file-earmark-text me-2\"></i>\r\n                <i v-else-if=\"activity.id.startsWith('pred_')\" class=\"bi bi-clipboard-data me-2\"></i>\r\n                {{ activity.title }}\r\n              </h6>\r\n              <small class=\"text-muted\">{{ formatDate(activity.time) }}</small>\r\n            </div>\r\n            <p class=\"mb-1\">{{ activity.description }}</p>\r\n          </a>\r\n          <div v-if=\"recentActivities.length === 0\" class=\"text-center py-4\">\r\n            <i class=\"bi bi-inbox fs-1 text-muted\"></i>\r\n            <p class=\"mt-2 text-muted\">暂无活动记录</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    \r\n    <!-- 刷新按钮 -->\r\n    <div class=\"text-center mt-4\">\r\n      <button class=\"btn btn-outline-primary\" @click=\"fetchDashboardData\">\r\n        <i class=\"bi bi-arrow-clockwise me-2\"></i>刷新数据\r\n      </button>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted } from 'vue'\r\nimport axios from 'axios'\r\n\r\nexport default {\r\n  name: 'Dashboard',\r\n  setup() {\r\n    const stats = ref({})\r\n    const recentActivities = ref([])\r\n    const loading = ref(false)\r\n\r\n    const fetchDashboardData = async () => {\r\n      loading.value = true\r\n      try {\r\n        const response = await axios.get('/api/dashboard')\r\n        stats.value = response.data.stats\r\n        recentActivities.value = response.data.activities\r\n      } catch (error) {\r\n        console.error('获取仪表盘数据失败:', error)\r\n      } finally {\r\n        loading.value = false\r\n      }\r\n    }\r\n\r\n    const formatDate = (date) => {\r\n      return new Date(date).toLocaleString()\r\n    }\r\n\r\n    onMounted(() => {\r\n      fetchDashboardData()\r\n    })\r\n\r\n    return {\r\n      stats,\r\n      recentActivities,\r\n      loading,\r\n      fetchDashboardData,\r\n      formatDate\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.dashboard {\r\n  animation: fadeIn 0.5s;\r\n}\r\n\r\n@keyframes fadeIn {\r\n  from { opacity: 0; }\r\n  to { opacity: 1; }\r\n}\r\n\r\n.card {\r\n  box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);\r\n  transition: transform 0.3s, box-shadow 0.3s;\r\n}\r\n\r\n.card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);\r\n}\r\n\r\n.card-title {\r\n  font-size: 1.1rem;\r\n}\r\n\r\n.list-group-item {\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.list-group-item:hover {\r\n  background-color: #f8f9fa;\r\n}\r\n\r\n.btn-outline-primary {\r\n  transition: all 0.3s;\r\n}\r\n\r\n.btn-outline-primary:hover {\r\n  transform: scale(1.05);\r\n}\r\n</style> "]}]}