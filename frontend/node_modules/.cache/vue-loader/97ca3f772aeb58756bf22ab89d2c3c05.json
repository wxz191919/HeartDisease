io-group>\r\n          </el-form-item>\r\n          \r\n          <el-form-item>\r\n            <el-button type=\"primary\" @click=\"handlePredict\">预测</el-button>\r\n            <el-button @click=\"resetForm\">重置</el-button>\r\n          </el-form-item>\r\n        </el-form>\r\n      </el-card>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  import { reactive } from 'vue'\r\n\r\n  export default {\r\n    name: \"DoctorPrediction\",\r\n    setup() {\r\n      const formData = reactive({\r\n        patientName: '',\r\n        age: 30,\r\n        gender: 'male'\r\n      })\r\n      \r\n      const handlePredict = () => {\r\n        console.log('预测数据:', formData)\r\n        // 这里添加预测逻辑\r\n      }\r\n      \r\n      const resetForm = () => {\r\n        formData.patientName = ''\r\n        formData.age = 30\r\n        formData.gender = 'male'\r\n      }\r\n      \r\n      return {\r\n        formData,\r\n        handlePredict,\r\n        resetForm\r\n      }\r\n    }\r\n  }\r\n  </script>\r\n\r\n<style scoped>\r\n.doctor-prediction {\r\n  padding: 20px;\r\n}\r\n\r\n.box-card {\r\n  margin-top: 20px;\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n</style>"]}]}