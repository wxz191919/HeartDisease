{"remainingRequest":"C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\node_modules\\thread-loader\\dist\\cjs.js!C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\node_modules\\babel-loader\\lib\\index.js!C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\node_modules\\vue-loader-v16\\dist\\index.js??ref--1-1!C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\src\\views\\user\\FeatureImportance.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\src\\views\\user\\FeatureImportance.vue","mtime":1773707218000},{"path":"C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\babel.config.js","mtime":1740459482000},{"path":"C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773905620310},{"path":"C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\node_modules\\thread-loader\\dist\\cjs.js","mtime":1773905597160},{"path":"C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\node_modules\\babel-loader\\lib\\index.js","mtime":1773905621400},{"path":"C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773905620310},{"path":"C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\node_modules\\vue-loader-v16\\dist\\index.js","mtime":1773905593150}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["echarts","markRaw","axios","name","data","featureImportanceData","loading","error","chartInstance","mounted","fetchData","window","addEventListener","handleResize","beforeUnmount","removeEventListener","dispose","methods","resize","featureMeta","description","category","token","localStorage","getItem","response","get","headers","rawData","length","Error","map","item","meta","feature","importance","$nextTick","initChart","err","console","$message","refreshData","clear","chartDom","$refs","featureImportanceChart","init","sortedData","sort","a","b","yAxisData","seriesData","option","tooltip","trigger","axisPointer","type","formatter","params","value","toFixed","grid","left","right","bottom","top","containLabel","xAxis","splitLine","lineStyle","color","axisLabel","yAxis","fontWeight","axisTick","show","axisLine","series","barWidth","showBackground","backgroundStyle","borderRadius","itemStyle","graphic","LinearGradient","offset","label","position","setOption","getProgressColor","getCategoryTag"],"sources":["C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\src\\views\\user\\FeatureImportance.vue"],"sourcesContent":["<template>\r\n  <div class=\"feature-importance-container pb-4\">\r\n    <div class=\"d-flex justify-content-between align-items-end mb-4 header-area\">\r\n      <div>\r\n        <h3 class=\"fw-bold text-dark m-0\">\r\n          <i class=\"el-icon-cpu text-primary mr-2\"></i>模型特征重要性分析 (SHAP Values)\r\n        </h3>\r\n        <p class=\"text-muted mt-2 mb-0\">\r\n          基于机器学习算法的全局可解释性分析，展示影响心脏病发病风险的核心驱动因素。\r\n        </p>\r\n      </div>\r\n      <el-button type=\"primary\" icon=\"el-icon-refresh\" @click=\"refreshData\" :loading=\"loading\" round>\r\n        重新运行特征评估\r\n      </el-button>\r\n    </div>\r\n\r\n    <el-row :gutter=\"20\" class=\"mb-4\">\r\n      <el-col :span=\"16\">\r\n        <el-card class=\"box-card shadow-sm border-0 h-100\" body-style=\"padding: 20px;\">\r\n          <template #header>\r\n            <div class=\"card-header d-flex justify-content-between align-items-center\">\r\n              <span class=\"fw-bold\"><i class=\"el-icon-data-analysis text-warning mr-2\"></i>全局特征重要性排名 (Top 10)</span>\r\n              <el-tag size=\"small\" type=\"success\" effect=\"plain\">XGBoost 模型</el-tag>\r\n            </div>\r\n          </template>\r\n          <div v-loading=\"loading\" class=\"chart-wrapper\">\r\n            <div ref=\"featureImportanceChart\" class=\"chart\"></div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n\r\n      <el-col :span=\"8\">\r\n        <el-card class=\"box-card shadow-sm border-0 h-100 insight-card\">\r\n          <template #header>\r\n            <div class=\"card-header\">\r\n              <span class=\"fw-bold\"><i class=\"el-icon-magic-stick text-purple mr-2\"></i>AI 智能洞察</span>\r\n            </div>\r\n          </template>\r\n          <div class=\"insight-content\">\r\n            <div class=\"insight-item mb-4\">\r\n              <h5 class=\"text-danger fw-bold\">1. 最关键风险因子</h5>\r\n              <p class=\"text-muted fs-6\">\r\n                模型表明，<strong>年龄 (Age)</strong> 和 <strong>收缩压 (sysBP)</strong> 是预测心脏病风险最具决定性的两个因素。对于这两项指标异常的患者，应优先进行干预。\r\n              </p>\r\n            </div>\r\n            <div class=\"insight-item mb-4\">\r\n              <h5 class=\"text-warning fw-bold\">2. 生活习惯的影响</h5>\r\n              <p class=\"text-muted fs-6\">\r\n                <strong>每日吸烟量 (cigsPerDay)</strong> 作为可控的生活习惯因素，其重要性排名第三。这为医生提供了明确的临床干预方向：强烈建议患者戒烟。\r\n              </p>\r\n            </div>\r\n            <div class=\"insight-item\">\r\n              <h5 class=\"text-primary fw-bold\">3. 血糖与胆固醇的协同</h5>\r\n              <p class=\"text-muted fs-6\">\r\n                虽然单一的空腹血糖 (glucose) 排名居中，但当它与高总胆固醇 (totChol) 并存时，模型给出的风险权重会呈指数级上升。\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <el-card class=\"box-card shadow-sm border-0\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <span class=\"fw-bold\"><i class=\"el-icon-document text-success mr-2\"></i>特征数据字典与权重明细</span>\r\n        </div>\r\n      </template>\r\n      <el-table\r\n        v-loading=\"loading\"\r\n        :data=\"featureImportanceData\"\r\n        style=\"width: 100%\"\r\n        :header-cell-style=\"{background:'#f8fafc', color:'#475569', fontWeight:'bold'}\"\r\n        border\r\n        stripe\r\n        hover\r\n      >\r\n        <el-table-column type=\"index\" label=\"排名\" width=\"80\" align=\"center\">\r\n          <template #default=\"scope\">\r\n            <span :class=\"{'top-rank': scope.$index < 3}\" class=\"rank-badge\">{{ scope.$index + 1 }}</span>\r\n          </template>\r\n        </el-table-column>\r\n\r\n        <el-table-column prop=\"feature\" label=\"特征字段 (Feature)\" width=\"150\" align=\"center\">\r\n          <template #default=\"scope\">\r\n            <code class=\"feature-code\">{{ scope.row.feature }}</code>\r\n          </template>\r\n        </el-table-column>\r\n\r\n        <el-table-column prop=\"category\" label=\"数据分类\" width=\"120\" align=\"center\">\r\n          <template #default=\"scope\">\r\n            <el-tag :type=\"getCategoryTag(scope.row.category)\" effect=\"light\" size=\"medium\">\r\n              {{ scope.row.category }}\r\n            </el-tag>\r\n          </template>\r\n        </el-table-column>\r\n\r\n        <el-table-column prop=\"description\" label=\"医学描述 (Description)\" min-width=\"250\"></el-table-column>\r\n\r\n        <el-table-column prop=\"importance\" label=\"相对重要性贡献 (SHAP Score)\" width=\"350\">\r\n          <template #default=\"scope\">\r\n            <div class=\"d-flex align-items-center\">\r\n              <span class=\"mr-3 fw-bold\" style=\"width: 40px;\">{{ (scope.row.importance * 100).toFixed(1) }}%</span>\r\n              <el-progress\r\n                :percentage=\"scope.row.importance * 100\"\r\n                :color=\"getProgressColor(scope.row.importance)\"\r\n                :show-text=\"false\"\r\n                :stroke-width=\"12\"\r\n                style=\"flex: 1;\"\r\n              ></el-progress>\r\n            </div>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport * as echarts from 'echarts';\r\nimport { markRaw } from 'vue';\r\nimport axios from 'axios'; // 🚀 引入 axios 用于请求后端接口\r\n\r\nexport default {\r\n  name: 'FeatureImportance',\r\n  data() {\r\n    return {\r\n      featureImportanceData: [],\r\n      loading: false,\r\n      error: null,\r\n      chartInstance: null\r\n    };\r\n  },\r\n  mounted() {\r\n    this.fetchData();\r\n    window.addEventListener('resize', this.handleResize);\r\n  },\r\n  beforeUnmount() {\r\n    window.removeEventListener('resize', this.handleResize);\r\n    if (this.chartInstance) {\r\n      this.chartInstance.dispose();\r\n    }\r\n  },\r\n  methods: {\r\n    handleResize() {\r\n      if (this.chartInstance) {\r\n        this.chartInstance.resize();\r\n      }\r\n    },\r\n    async fetchData() {\r\n      this.loading = true;\r\n      this.error = null;\r\n\r\n      // 🚀 给冰冷的模型英文特征，穿上好看的中文外套\r\n      const featureMeta = {\r\n        'age': { description: '患者年龄 (岁)', category: '基础信息' },\r\n        'sysBP': { description: '收缩压/高压 (mmHg)', category: '生理指标' },\r\n        'cigsPerDay': { description: '每日吸烟量 (支)', category: '生活习惯' },\r\n        'diaBP': { description: '舒张压/低压 (mmHg)', category: '生理指标' },\r\n        'totChol': { description: '总胆固醇水平 (mg/dL)', category: '生化指标' },\r\n        'glucose': { description: '空腹血糖水平 (mg/dL)', category: '生化指标' },\r\n        'BMI': { description: '身体质量指数', category: '基础信息' },\r\n        'heartRate': { description: '静息心率 (次/分)', category: '生理指标' },\r\n        'male': { description: '性别 (1=男; 0=女)', category: '基础信息' },\r\n        'diabetes': { description: '是否有糖尿病病史 (1=是; 0=否)', category: '疾病史' }\r\n      };\r\n\r\n      try {\r\n        const token = localStorage.getItem('token');\r\n\r\n        // 🚀 调用真实的后端接口获取特征重要性\r\n        const response = await axios.get('http://localhost:5003/api/predictions/importance', {\r\n          headers: { 'Authorization': `Bearer ${token}` }\r\n        });\r\n\r\n        const rawData = response.data.data || [];\r\n\r\n        if (rawData.length === 0) {\r\n          throw new Error('模型未返回有效特征数据');\r\n        }\r\n\r\n        // 把后端的真实分数和前端的中文翻译完美结合\r\n        this.featureImportanceData = rawData.map(item => {\r\n          const meta = featureMeta[item.feature] || { description: '未知特征', category: '其他' };\r\n          return {\r\n            feature: item.feature,\r\n            importance: item.importance,\r\n            description: meta.description,\r\n            category: meta.category\r\n          };\r\n        });\r\n\r\n        this.$nextTick(() => {\r\n          this.initChart();\r\n        });\r\n\r\n      } catch (err) {\r\n        console.error('获取特征重要性数据失败:', err);\r\n        this.error = '无法连接到 AI 模型接口，或模型尚未就绪。';\r\n        this.$message && this.$message.error(this.error);\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n    refreshData() {\r\n      if (this.chartInstance) {\r\n        this.chartInstance.clear();\r\n      }\r\n      this.fetchData();\r\n    },\r\n    initChart() {\r\n      const chartDom = this.$refs.featureImportanceChart;\r\n      if (!chartDom) return;\r\n\r\n      this.chartInstance = markRaw(echarts.init(chartDom));\r\n\r\n      const sortedData = [...this.featureImportanceData].sort((a, b) => a.importance - b.importance);\r\n      const yAxisData = sortedData.map(item => item.feature);\r\n      const seriesData = sortedData.map(item => item.importance * 100);\r\n\r\n      const option = {\r\n        tooltip: {\r\n          trigger: 'axis',\r\n          axisPointer: { type: 'shadow' },\r\n          formatter: function (params) {\r\n            let data = params[0];\r\n            return `<div style=\"padding: 5px;\">\r\n                      <div style=\"font-weight:bold;margin-bottom:5px;\">${data.name}</div>\r\n                      重要性贡献: <span style=\"color:#0d6efd;font-weight:bold;\">${data.value.toFixed(2)}%</span>\r\n                    </div>`;\r\n          }\r\n        },\r\n        grid: {\r\n          left: '3%',\r\n          right: '8%',\r\n          bottom: '3%',\r\n          top: '3%',\r\n          containLabel: true\r\n        },\r\n        xAxis: {\r\n          type: 'value',\r\n          name: '重要性 (%)',\r\n          splitLine: { lineStyle: { type: 'dashed', color: '#e2e8f0' } },\r\n          axisLabel: { color: '#64748b' }\r\n        },\r\n        yAxis: {\r\n          type: 'category',\r\n          data: yAxisData,\r\n          axisLabel: { fontWeight: 'bold', color: '#334155' },\r\n          axisTick: { show: false },\r\n          axisLine: { lineStyle: { color: '#cbd5e1' } }\r\n        },\r\n        series: [\r\n          {\r\n            name: '重要性',\r\n            type: 'bar',\r\n            data: seriesData,\r\n            barWidth: '50%',\r\n            showBackground: true,\r\n            backgroundStyle: { color: 'rgba(180, 180, 180, 0.05)', borderRadius: [0, 4, 4, 0] },\r\n            itemStyle: {\r\n              borderRadius: [0, 4, 4, 0],\r\n              color: new echarts.graphic.LinearGradient(0, 0, 1, 0, [\r\n                { offset: 0, color: '#3b82f6' },\r\n                { offset: 1, color: '#8b5cf6' }\r\n              ])\r\n            },\r\n            label: {\r\n              show: true,\r\n              position: 'right',\r\n              formatter: '{c}%',\r\n              color: '#64748b',\r\n              fontWeight: 'bold'\r\n            }\r\n          }\r\n        ]\r\n      };\r\n\r\n      this.chartInstance.setOption(option);\r\n    },\r\n    getProgressColor(importance) {\r\n      if (importance >= 0.20) return '#ef4444';\r\n      if (importance >= 0.10) return '#f59e0b';\r\n      if (importance >= 0.05) return '#3b82f6';\r\n      return '#94a3b8';\r\n    },\r\n    getCategoryTag(category) {\r\n      const map = {\r\n        '基础信息': 'info',\r\n        '生理指标': 'danger',\r\n        '生化指标': 'warning',\r\n        '生活习惯': 'success',\r\n        '疾病史': 'primary'\r\n      };\r\n      return map[category] || 'info';\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.feature-importance-container {\r\n  pa