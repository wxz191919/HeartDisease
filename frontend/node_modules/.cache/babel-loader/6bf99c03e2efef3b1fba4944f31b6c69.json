\n          <div class=\"user-card p-3 rounded-4 mb-3 d-flex align-items-center\">\r\n            <div class=\"avatar bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3\" style=\"width: 40px; height: 40px; font-weight: bold;\">\r\n              {{ username.charAt(0).toUpperCase() }}\r\n            </div>\r\n            <div class=\"user-info overflow-hidden\">\r\n              <div class=\"text-white fw-bold text-truncate\">{{ username }}</div>\r\n              <div class=\"text-secondary fs-7\">主治医师</div>\r\n            </div>\r\n          </div>\r\n\r\n          <button class=\"btn btn-logout w-100 d-flex align-items-center justify-content-center fw-bold\" @click=\"handleLogout\">\r\n            <i class=\"bi bi-box-arrow-right me-2 fs-5\"></i> 安全退出系统\r\n          </button>\r\n        </div>\r\n\r\n      </div>\r\n    </nav>\r\n    <main class=\"main-content\"><router-view></router-view></main>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { useStore } from 'vuex'; import { useRouter } from 'vue-router'; import { computed, onMounted } from 'vue'; import { Dropdown } from 'bootstrap'\r\n\r\nexport default {\r\n  name: 'Layout',\r\n  setup() {\r\n    const store = useStore(); const router = useRouter()\r\n    const username = computed(() => store.getters.currentUser?.username || '未登录')\r\n    const handleLogout = () => { store.dispatch('logout'); router.push('/login') }\r\n\r\n    onMounted(() => {\r\n      document.querySelectorAll('.dropdown-toggle').forEach(el => new Dropdown(el))\r\n      const userDropdown = document.getElementById('userDropdown')\r\n      if (userDropdown) new Dropdown(userDropdown)\r\n    })\r\n\r\n    return { username, handleLogout }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* ================== 全局与布局结构 ================== */\r\n/* 🚀 核心修复：背景强制透明，让全局粒子网格透上来 */\r\n.layout-container { display: flex; min-height: 100vh; background: transparent; }\r\n.main-content { margin-left: 260px; padding: 2rem; width: calc(100% - 260px); min-height: 100vh; background: transparent; }\r\n.fs-7 { font-size: 0.85rem; }\r\n\r\n/* ================== 侧边栏高级样式 ================== */\r\n.custom-sidebar {\r\n  width: 260px;\r\n  position: fixed;\r\n  height: 100vh;\r\n  /* 高级深邃蓝渐变背景 */\r\n  background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);\r\n  box-shadow: 4px 0 20px rgba(0,0,0,0.05);\r\n  z-index: 1000;\r\n}\r\n\r\n.sidebar-header {\r\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\r\n}\r\n\r\n/* ================== 菜单项极致美化 ================== */\r\n.custom-nav-link {\r\n  color: #94a3b8 !important; /* 默认未选中颜色 */\r\n  padding: 0.85rem 1.2rem;\r\n  margin-bottom: 0.4rem;\r\n  border-radius: 12px;\r\n  font-weight: 500;\r\n  display: flex;\r\n  align-items: center;\r\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\r\n  border: 1px solid transparent;\r\n}\r\n\r\n/* 悬停状态 (丝滑右移效果) */\r\n.custom-nav-link:hover {\r\n  background-color: rgba(241, 245, 249, 0.05);\r\n  color: #f8fafc !important;\r\n  transform: translateX(5px);\r\n}\r\n\r\n/* 激活状态 (科幻发光感) */\r\n.custom-nav-link.router-link-active {\r\n  background: linear-gradient(90deg, rgba(59, 130, 246, 0.15) 0%, rgba(59, 130, 246, 0.05) 100%);\r\n  color: #60a5fa !important;\r\n  font-weight: 600;\r\n  border-left: 4px solid #3b82f6;\r\n  border-radius: 0 12px 12px 0;\r\n}\r\n.custom-nav-link.router-link-active i {\r\n  color: #3b82f6 !important;\r\n}\r\n\r\n/* ================== 折叠子菜单 ================== */\r\n.custom-submenu {\r\n  background-color: rgba(0, 0, 0, 0.2);\r\n  border-radius: 12px;\r\n  margin: 0.2rem 1rem 0.5rem 1rem;\r\n  padding: 0.5rem 0;\r\n}\r\n.custom-sub-link {\r\n  color: #64748b !important;\r\n  padding: 0.5rem 1rem 0.5rem 2.5rem;\r\n  font-size: 0.9rem;\r\n  transition: all 0.2s ease;\r\n  border-radius: 8px;\r\n  margin: 0.1rem 0.5rem;\r\n}\r\n.custom-sub-link:hover {\r\n  color: #e2e8f0 !important;\r\n  background-color: rgba(255, 255, 255, 0.05);\r\n}\r\n.custom-sub-link.router-link-active {\r\n  color: #38bdf8 !important;\r\n  font-weight: bold;\r\n}\r\n\r\n/* ================== 底部用户卡片与按钮 ================== */\r\n.sidebar-footer { border-top: 1px solid rgba(255, 255, 255, 0.05); }\r\n.user-card { background-color: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); }\r\n\r\n.btn-logout {\r\n  background-color: rgba(239, 68, 68, 0.1);\r\n  color: #ef4444;\r\n  border: 1px solid rgba(239, 68, 68, 0.2);\r\n  border-radius: 12px;\r\n  padding: 0.75rem;\r\n  transition: all 0.3s ease;\r\n}\r\n.btn-logout:hover {\r\n  background-color: #ef4444;\r\n  color: #fff;\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);\r\n}\r\n\r\n/* 修改自带的下拉箭头对齐 */\r\n.dropdown-toggle::after {\r\n  margin-left: auto;\r\n  vertical-align: middle;\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAkB;;EACtBA,KAAK,EAAC;AAAwB;;EAC5BA,KAAK,EAAC;AAAyC;;EAU9CA,KAAK,EAAC;AAAuD;;EAC3DA,KAAK,EAAC;AAAU;;EAMhBA,KAAK,EAAC;AAAU;;EAMhBA,KAAK,EAAC;AAAmB;;EAIvBA,KAAK,EAAC,yCAAyC;EAACC,EAAE,EAAC;;;EACjDD,KAAK,EAAC;AAAU;;EAKhBA,KAAK,EAAC;AAAU;;EAYpBA,KAAK,EAAC;AAAU;;EAKhBA,KAAK,EAAC;AAAU;;EAKhBA,KAAK,EAAC;AAAU;;EAKhBA,KAAK,EAAC;AAAU;;EAOjBA,KAAK,EAAC;AAA4B;;EAChCA,KAAK,EAAC;AAAwD;;EAC5DA,KAAK,EAAC,mGAAmG;EAACE,KAAqD,EAArD;IAAA;IAAA;IAAA;EAAA;;;EAG1GF,KAAK,EAAC;AAA2B;;EAC/BA,KAAK,EAAC;AAAkC;;EAYjDA,KAAK,EAAC;AAAc;;;;uBAvF5BG,mBAAA,CAwFM,OAxFNC,UAwFM,GAvFJC,mBAAA,CAqFM,OArFNC,UAqFM,GApFJD,mBAAA,CAmFM,OAnFNE,UAmFM,G,8cAzEJF,mBAAA,CAuDK,MAvDLG,UAuDK,GAtDHH,mBAAA,CAIK,MAJLI,UAIK,GAHHC,YAAA,CAEcC,sBAAA;IAFDC,EAAE,EAAC,mBAAmB;IAACZ,KAAK,EAAC;;sBACxC,MAA4Ca,MAAA,QAAAA,MAAA,OAA5CR,mBAAA,CAA4C;MAAzCL,KAAK,EAAC;IAA8B,cAAKK,mBAAA,CAAgB,cAAV,KAAG,M;;QAIzDA,mBAAA,CAIK,MAJLS,UAIK,GAHHJ,YAAA,CAEcC,sBAAA;IAFDC,EAAE,EAAC,kBAAkB;IAACZ,KAAK,EAAC;;sBACvC,MAAsCa,MAAA,QAAAA,MAAA,OAAtCR,mBAAA,CAAsC;MAAnCL,KAAK,EAAC;IAAwB,cAAKK,mBAAA,CAAiB,cAAX,MAAI,M;;QAIpDA,mBAAA,CAgBK,MAhBLU,UAgBK,G,0BAfHV,mBAAA,CAEI;IAFDL,KAAK,EAAC,0CAA0C;IAACgB,IAAI,EAAC,GAAG;IAACC,IA