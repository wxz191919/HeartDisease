,"_withCtx","_createElementVNode","_hoisted_2","_hoisted_3","_toDisplayString","_createVNode","_component_el_tag","type","$options","riskLevelTagType","effect","size","riskLevel","_component_el_button","icon","onClick","_cache","$event","_ctx","$router","back","plain","_hoisted_4","_hoisted_5","_normalizeClass","probability","_hoisted_6","predictionTime","_hoisted_7","fetchDeepSeekAnalysis","loading","dsLoading","round","_hoisted_8","dsReport","innerHTML","formattedDsReport","_hoisted_10","_hoisted_11","_hoisted_12","_component_el_alert","title","_component_el_collapse","activeNotices","_component_el_collapse_item","name","pageLoading"],"sources":["C:\\Users\\Administrator\\Desktop\\HeartDisease\\frontend\\src\\views\\doctor\\PredictionDetail.vue"],"sourcesContent":["<template>\n  <div class=\"doctor-prediction-detail\" v-loading=\"pageLoading\">\n\n    <el-card class=\"mb-4 shadow-sm\" v-if=\"prediction.patientName\">\n      <template #header>\n        <div class=\"card-header d-flex justify-content-between align-items-center\">\n          <h3 class=\"m-0\"><i class=\"el-icon-user-solid text-primary\"></i> 患者：{{ prediction.patientName }} 临床风险评估</h3>\n          <div>\n            <el-tag :type=\"riskLevelTagType\" effect=\"dark\" size=\"medium\" class=\"mr-2\">{{ prediction.riskLevel }}</el-tag>\n            <el-button size=\"small\" icon=\"el-icon-back\" @click=\"$router.back()\" plain>返回列表</el-button>\n          </div>\n        </div>\n      </template>\n      <div class=\"real-data-row text-center\">\n        <div class=\"data-item\">\n          <h5 class=\"text-muted\">模型推演高危概率</h5>\n          <h1 :class=\"riskLevelTagType === 'danger' ? 'text-danger' : 'text-primary'\">\n            {{ prediction.probability }}%\n          </h1>\n        </div>\n        <div class=\"data-item\">\n          <h5 class=\"text-muted\">评估生成时间</h5>\n          <h4>{{ prediction.predictionTime }}</h4>\n        </div>\n        <div class=\"data-item\">\n          <h5 class=\"text-muted\">驱动引擎</h5>\n          <h4>Cardio-AI v2.0 & DeepSeek V3</h4>\n        </div>\n      </div>\n    </el-card>\n\n    <el-card class=\"mb-4 shadow-sm ai-card\" v-if=\"prediction.patientName\">\n      <template #header>\n        <div class=\"card-header d-flex justify-content-between align-items-center\">\n          <h3 class=\"m-0 ai-title\">\n            <i class=\"el-icon-cpu\"></i> DeepSeek 临床辅助诊断报告\n          </h3>\n          <el-button type=\"primary\" size=\"small\" icon=\"el-icon-refresh\" @click=\"fetchDeepSeekAnalysis\" :loading=\"dsLoading\" round>\n            重新生成靶向分析\n          </el-button>\n        </div>\n      </template>\n\n      <div class=\"ai-report-container\" v-loading=\"dsLoading\" element-loading-text=\"DeepSeek 正在结合患者指标进行特异化深度思考中...\" element-loading-spinner=\"el-icon-loading\">\n        <div v-if=\"dsReport\" class=\"ai-report-content\" v-html=\"formattedDsReport\"></div>\n        <div v-else-if=\"!dsLoading\" class=\"text-center text-muted py-5\">\n          等待 AI 引擎响应...\n        </div>\n      </div>\n    </el-card>\n\n    <div class=\"notice-section\">\n      <el-card>\n        <template #header>\n          <div class=\"card-header\">\n            <h3><i class=\"el-icon-warning\"></i> 临床常规干预指南</h3>\n          </div>\n        </template>\n        <div class=\"notice-content\">\n          <el-alert title=\"高危紧急情况处理\" type=\"error\" show-icon>\n            <ul>\n              <li>如出现<strong>持续胸痛、呼吸困难、晕厥</strong>等症状，请立即启动院内急救预案。</li>\n              <li>开具硝酸甘油等急救药物处方。</li>\n            </ul>\n          </el-alert>\n\n          <el-collapse v-model=\"activeNotices\" class=\"mt-3\">\n            <el-collapse-item title=\"日常医嘱建议\" name=\"daily\">\n              <ul class=\"notice-list\">\n                <li>叮嘱患者定期监测血压、血糖和血脂水平</li>\n                <li>处方药物需按时服用，强调不可擅自停药的风险</li>\n                <li>建议适度运动，但严禁近期进行剧烈活动</li>\n                <li>强制要求戒烟限酒，远离二手烟</li>\n              </ul>\n            </el-collapse-item>\n            <el-collapse-item title=\"复诊排期提醒\" name=\"checkup\">\n              <ul class=\"notice-list\">\n                <li>每 3 个月复查心电图和心肌酶谱</li>\n                <li>每半年进行一次全面的心血管系统影像学检查</li>\n              </ul>\n            </el-collapse-item>\n          </el-collapse>\n        </div>\n      </el-card>\n    </div>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios'\n\nexport default {\n  name: 'DoctorPredictionDetail',\n  data() {\n    return {\n      activeNotices: ['daily', 'checkup'],\n      pageLoading: true,\n      prediction: {\n        patientName: '',\n        riskLevel: '未知',\n        probability: 0,\n        predictionTime: ''\n      },\n      // 存储患者具体生理指标\n      features: {},\n      // DeepSeek 专属状态\n      dsLoading: false,\n      dsReport: ''\n    }\n  },\n  computed: {\n    riskLevelTagType() {\n      const map = {\n        '低风险': 'success',\n        '中风险': 'warning',\n        '高风险': 'danger'\n      }\n      return map[this.prediction.riskLevel] || 'info'\n    },\n    // 将 AI 返回的换行符转为 HTML 换行，并高亮部分医学警示词\n    formattedDsReport() {\n      if (!this.dsReport) return ''\n      let text = this.dsReport.replace(/\\n/g, '<br/>')\n      // 用正则给危险词汇飘红加粗\n      text = text.replace(/(异常|高风险|罪魁祸首|高危|立刻|必须|严禁|超标|恶化)/g, '<strong style=\"color: #F56C6C;\">$1</strong>')\n      // 给建议性词汇加蓝加粗\n      text = text.replace(/(建议|控制在|医嘱|处方|靶向|临床剖析)/g, '<strong style=\"color: #409EFF;\">$1</strong>')\n      return text\n    }\n  },\n  async mounted() {\n    // 1. 抓取URL上的真实数据库ID\n    const predictionId = this.$route.params.id\n    if (!predictionId) {\n      this.pageLoading = false\n      return\n    }\n\n    try {\n      const token = localStorage.getItem('token')\n      const response = await axios.get(`http://localhost:5003/api/predictions/${predictionId}`, {\n        headers: { 'Authorization': `Bearer ${token}` }\n      })\n\n      const data = response.data\n\n      this.prediction = {\n        patientName: data.patientName || data.patient_name || '未知患者',\n        riskLevel: data.riskLevel || data.risk_level || '未知',\n        probability: data.probability < 1 ? (data.probability * 100).toFixed(1) : parseFloat(data.probability).toFixed(1),\n        predictionTime: data.predictionTime ? data.predictionTime.replace('T', ' ').substring(0, 16) : new Date().toLocaleString()\n      }\n\n      // 提取特征\n      if (typeof data.features === 'string') {\n        try { this.features = JSON.parse(data.features) } catch(e) { this.features = {} }\n      } else {\n        this.features = data.features || {}\n      }\n\n      // 基础数据加载完毕后，立刻召唤 DeepSeek！\n      this.fetchDeepSeekAnalysis()\n\n    } catch (error) {\n      console.error('获取真实预测详情失败:', error)\n      this.$message && this.$message.error('读取数据库详情失败')\n    } finally {\n      this.pageLoading = false\n    }\n  },\n  methods: {\n    // 🚀 核心：纯前端直连 DeepSeek，专为医生定制的特异化分析\n    async fetchDeepSeekAnalysis() {\n      this.dsLoading = true\n      this.dsReport = ''\n\n      try {\n        const metricsMap = {\n          age: '年龄', sysBP: '收缩压', diaBP: '舒张压', totChol: '总胆固醇',\n          glucose: '空腹血糖', bmi: 'BMI指数', BMI: 'BMI指数', heartRate: '静息心率',\n          cigsPerDay: '日吸烟量', male: '性别(1男0女)', diabetes: '糖尿病史(1有0无)'\n        }\n\n        let metricsText = ''\n        for (const [key, val] of Object.entries(this.features)) {\n          const cnName = metricsMap[key] || key\n          metricsText += `- ${cnName}: ${val}\\n`\n        }\n\n        // 🚀 医生版专属强化 Prompt\n        const prompt = `作为心血管临床AI辅助诊断系统，请为主治医生生成针对该患者的【特异化临床分析报告】。绝不能使用通用套话！\n\n患者姓名：${this.prediction.patientName}\nAI预测高危概率：${this.prediction.probability}% (${this.prediction.riskLevel})\n\n【患者临床体征数据】：\n${metricsText}\n\n请按以下3个维度输出临床报告（Markdown排版）：\n### 1. 异常指标临床剖析\n（逐一精读偏离正常值的指标，向医生提示其单独及协同致病风险。正常指标忽略，异常指标重点预警）\n\n### 2. 核心病理归因\n（结合高达/低至 ${this.prediction.probability}% 的风险率，指出引发高危的最核心因素）\n\n### 3. 靶向医疗干预处方\n（为医生提供明确的数值化医疗干预建议，例如降压靶标、用药建议方向、生活干预细则）`\n\n        // 🚀 复用你的真实 Key，直接敲门\n        const apiKey = 'sk-513768d242da4afdbbdee96ec7a6da59'\n\n        const response = await fetch('https://api.deepseek.com/chat/completions', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json',\n            'Authorization': `Bearer ${apiKey}`\n          },\n          body: JSON.stringify({\n            model: 'deepseek-chat',\n            messages: [\n              { role: 'system', content: '你是一个专业、严谨的心血管AI专家诊断系统。' },\n              { role: 'user', content: prompt }\n            ],\n            temperature: 0.7\n          })\n        })\n\n        if (!response.ok) {\n          throw new Error('网络请求异常，状态码: ' + response.status)\n        }\n\n        const data = await response.json()\n\n        // 渲染 DeepSeek 给医生的报告\n        this.dsReport = data.choices[0].message.content\n\n      } catch (error) {\n        console.error('DeepSeek 请求失败:', error)\n        this.dsReport = `<div style=\"background-color: #fef0f0; border: 1px solid #fde2e2; color: #f56c6c; padding: 15px; border-radius: 4px;\">\n          <strong><i class=\"el-icon-error\"></i> AI 临床诊断生成失败</strong><br/><br/>\n          未能成功连接到 DeepSeek 官方接口。请检查网络状态或 API 余额。<br/>\n          详细报错：${error.message}\n        </div>`\n      } finally {\n        this.dsLoading = false\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.doctor-prediction-detail {\n  padding: 20px;\n}\n.card-header {\n  margin-bottom: 0;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.mb-4 {\n  margin-bottom: 20px;\n}\n.mt-3 {\n  margin-top: 15px;\n}\n.real-data-row {\n  display: flex;\n  justify-content: space-around;\n  padding: 20px 0;\n}\n.data-item h1, .data-item h4 {\n  margin-top: 10px;\n  font-weight: bold;\n}\n.notice-list li {\n  line-height: 2;\n  color: #555;\n}\n\n/* AI 卡片专属样式 */\n.ai-card {\n  border: 1px solid #c6e2ff;\n}\n.ai-title {\n  color: #409EFF;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n.ai-report-container {\n  min-height: 200px;\n  padding: 10px 15px;\n}\n.ai-report-content {\n  font-size: 15px;\n  line-height: 1.8;\n  color: #303133;\n}\n.text-danger {\n  color: #F56C6C;\n}\n.text-primary {\n  color: #409EFF;\n}\n.mr-2 {\n  margin-right: 10px;\n}\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAA0B;;EAI1BA,KAAK,EAAC;AAA+D;;EACpEA,KAAK,EAAC;AAAK;;EAOdA,KAAK,EAAC;AAA2B;;EAC/BA,KAAK,EAAC;AAAW;;EAMjBA,KAAK,EAAC;AAAW;;EAajBA,KAAK,EAAC;AAA+D;;EAUvEA,KAAK,EAAC,qBAAqB;EAAuB,sBAAoB,EAAC,gCAAgC;EAAC,yBAAuB,EAAC;;;;;EAEvGA,KAAK,EAAC;;;EAMjCA,KAAK,EAAC;AAAgB;;EAOlBA,KAAK,EAAC;AAAgB;;;;;;;;;wCAzDjCC,mBAAA,CAoFM,OApFNC,UAoFM,GAlFkCC,KAAA,CAAAC,UAAU,CAACC,WAAW,I,cAA5DC,YAAA,CA0BUC,kBAAA;;IA1BDP,KAAK,EAAC;;IACFQ,MAAM,EAAAC,QAAA,CACf,MAMM,CANNC,mBAAA,CAMM,OANNC,UAMM,GALJD,mBAAA,CAA2G,MAA3GE,UAA2G,G,0BAA3FF,mBAAA,CAA+C;MAA5CV,KAAK,EAAC;IAAiC,e,iBAAK,MAAI,GAAAa,gBAAA,CAAGV,KAAA,CAAAC,UAAU,CAACC,WAAW,IAAG,SAAO,K,GACtGK,mBAAA,CAGM,cAFJI,YAAA,CAA6GC,iBAAA;MAApGC,IAAI,EAAEC,QAAA,CAAAC,gBAAgB;MAAEC,MAAM,EAAC,MAAM;MAACC,IAAI,EAAC,QAAQ;MAACpB,KAAK,EAAC;;wBAAO,MAA0B,C,kCAAvBG,KAAA,CAAAC,UAAU,CAACiB,SAAS,M;;qBACjGP,YAAA,CAA0FQ,oBAAA;MAA/EF,IAAI,EAAC,OAAO;MAACG,IAAI,EAAC,cAAc;MAAEC,OAAK,EAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEC,IAAA,CAAAC,OAAO,CAACC,IAAI;MAAIC,KAAK,EAAL;;wBAAM,MAAIL,MAAA,QAAAA,MAAA,O,iBAAJ,MAAI,E;;;sBAIpF,MAeM,CAfNf,mBAAA,CAeM,OAfNqB,UAeM,GAdJrB,mBAAA,CAKM,OALNsB,UAKM,G,0BAJJtB,mBAAA,CAAoC;MAAhCV,KAAK,EAAC;IAAY,GAAC,UAAQ,QAC/BU,mBAAA,CAEK;MAFAV,KAAK,EAAAiC,eAAA,CAAEhB,QAAA,CAAAC,gBAAgB;wBACvBf,KAAA,CAAAC,UAAU,CAAC8B,WAAW,IAAG,IAC9B,K,GAEFxB,mBAAA,CAGM,OAHNyB,UAGM,G,0BAFJzB,mBAAA,CAAkC;MAA9BV,KAAK,EAAC;IAAY,GAAC,QAAM,QAC7BU,mBAAA,CAAwC,YAAAG,gBAAA,CAAjCV,KAAA,CAAAC,UAAU,CAACgC,cAAc,M,6BAElC1B,mBAAA,CAGM;MAHDV,KAAK,EAAC;IAAW,IACpBU,mBAAA,CAAgC;MAA5BV,KAAK,EAAC;IAAY,GAAC,MAAI,GAC3BU,mBAAA,CAAqC,YAAjC,8BAA4B,E;;uCAKQP,KAAA,CAAAC,UAAU,CAACC,WAAW,I,cAApEC,YAAA,CAkBUC,kBAAA;;IAlBDP,KAAK,EAAC;;IACFQ,MAAM,EAAAC,QAAA,CACf,MAOM,CAPNC,mBAAA,CAOM,OAPN2B,UAOM,G,0BANJ3B,mBAAA,CAEK;MAFDV,KAAK,EAAC;IAAc,IACtBU,mBAAA,CAA2B;MAAxBV,KAAK,EAAC;IAAa,I,iBAAK,qBAC7B,E,QACAc,YAAA,CAEYQ,oBA